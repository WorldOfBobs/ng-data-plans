BOT_TOKEN=your_telegram_bot_token_here
POLL_INTERVAL_SECONDS=900
ALERT_THRESHOLD_PCT=2.0

# DEFAULT_COUNTRY: set to a country code (NG, GH, KE) for single-country bots
