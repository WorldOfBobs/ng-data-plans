<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.fxbob.nigeria</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/gravy/dev/nigeria-daily-tools/fx-tracker/venv/bin/python3</string>
    <string>/Users/gravy/dev/nigeria-daily-tools/fx-tracker/bot.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/gravy/dev/nigeria-daily-tools/fx-tracker</string>

  <key>StandardOutPath</key>
  <string>/Users/gravy/dev/nigeria-daily-tools/fx-tracker/bot.log</string>

